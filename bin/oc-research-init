#!/usr/bin/env bash
set -euo pipefail
if [ "$#" -lt 1 ]; then
  echo "Usage: oc-research-init <request text>" >&2
  exit 2
fi
request="$*"
if [ "${#request}" -gt 4000 ]; then
  echo "request too long (max 4000 chars)" >&2
  exit 2
fi
job_dir="$({ /root/operator/bin/op job new --workflow research-init --request "$request"; } )"
/root/operator/bin/op run "$job_dir" --timeout 900
project_id=""
if [ -f "$job_dir/artifacts/project_id.txt" ]; then
  project_id="$(cat "$job_dir/artifacts/project_id.txt")"
fi
if [ -n "$project_id" ]; then
  echo "PROJECT_ID=$project_id"
fi
