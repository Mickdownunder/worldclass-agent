#!/usr/bin/env bash
set -euo pipefail

goal="${*:-}"
if [ -z "$goal" ]; then
  echo "Usage: oc-brain-think <goal>" >&2
  exit 2
fi
if [ "${#goal}" -gt 1200 ]; then
  echo "goal too long (max 1200 chars)" >&2
  exit 2
fi

source /root/operator/conf/secrets.env 2>/dev/null || true
exec timeout 180 /root/operator/bin/brain think --goal "$goal"
