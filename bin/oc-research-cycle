#!/usr/bin/env bash
set -euo pipefail
request="${*:-telegram trigger}"
if [ "${#request}" -gt 4000 ]; then
  echo "request too long (max 4000 chars)" >&2
  exit 2
fi
job_dir="$({ /root/operator/bin/op job new --workflow research-cycle --request "$request"; } )"
exec /root/operator/bin/op run "$job_dir"
