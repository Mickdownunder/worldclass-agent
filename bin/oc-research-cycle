#!/usr/bin/env bash
set -euo pipefail
if [ "$#" -lt 1 ]; then
  echo "Usage: oc-research-cycle <project_id>" >&2
  exit 2
fi
project_id="$1"
if ! printf '%s' "$project_id" | grep -Eq '^proj-[A-Za-z0-9_-]+$'; then
  echo "project_id must match proj-*" >&2
  exit 2
fi
exec bash /root/operator/tools/run-research-cycle-until-done.sh "$project_id"
