#!/usr/bin/env bash
set -euo pipefail
if [ "$#" -gt 1 ]; then
  echo "Usage: oc-job-status [limit]" >&2
  exit 2
fi
limit="${1:-20}"
if ! [[ "$limit" =~ ^[0-9]{1,3}$ ]]; then
  echo "limit must be numeric (1-999)" >&2
  exit 2
fi
if [ "$limit" -lt 1 ] || [ "$limit" -gt 200 ]; then
  echo "limit out of range (1-200)" >&2
  exit 2
fi
exec /root/operator/bin/op job status --limit "$limit"
