#!/usr/bin/env bash
set -euo pipefail
if [ "$#" -ne 1 ]; then
  echo "Usage: oc-queue-run <all|index>" >&2
  exit 2
fi
mode="$1"
if [ "$mode" = "all" ]; then
  job_dir="$({ RUN_MODE=all /root/operator/bin/op job new --workflow queue-run --request telegram; } )"
  exec /root/operator/bin/op run "$job_dir" --timeout 600
fi
if ! [[ "$mode" =~ ^[0-9]{1,3}$ ]]; then
  echo "index must be numeric or all" >&2
  exit 2
fi
if [ "$mode" -lt 1 ] || [ "$mode" -gt 500 ]; then
  echo "index out of range (1-500)" >&2
  exit 2
fi
job_dir="$({ RUN_MODE=index RUN_INDEX="$mode" /root/operator/bin/op job new --workflow queue-run --request telegram; } )"
exec /root/operator/bin/op run "$job_dir" --timeout 600
